{
  "@context": {
    "@vocab": "https://schema.org/",
    "refarm": "https://refarm.app/vocab#",
    "nostr": "https://nostr.com/vocab#",
    "crdt": "https://crdt.tech/vocab#"
  },

  "@graph": [
    {
      "@type": "DataCatalog",
      "@id": "urn:refarm:sovereign-graph:v1",
      "name": "Refarm Sovereign Data Graph",
      "description": "The user's personal, portable, offline-first data graph. All nodes are normalised to JSON-LD before SQLite persistence, ensuring semantic interoperability across any platform.",
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "refarm:schemaVersion": "0.1.0",
      "refarm:storageBackend": "SQLite/OPFS",
      "refarm:syncProtocol": "CRDT + Nostr"
    },

    {
      "@comment": "Example 1 — A contact ingested via a 'WhatsApp Bridge' plugin",
      "@type": "Person",
      "@id": "urn:whatsapp-bridge:contact-alice-42",
      "name": "Alice Souza",
      "telephone": "+55 11 99999-0000",
      "email": "alice@example.com",
      "image": "https://cdn.example.com/avatar/alice.jpg",
      "refarm:sourcePlugin": "whatsapp-bridge",
      "refarm:ingestedAt": "2026-03-04T04:00:00Z",
      "refarm:confidence": 0.95,
      "refarm:rawReference": {
        "@type": "refarm:RawCapture",
        "refarm:pluginPayload": {
          "wa_id": "5511999990000",
          "name": "Alice Souza",
          "status": "Oi, tudo bem?"
        },
        "refarm:capturedAt": "2026-03-04T03:58:12Z"
      },
      "crdt:vectorClock": {
        "device-A": 7,
        "device-B": 3
      }
    },

    {
      "@comment": "Example 2 — A message ingested via the same plugin",
      "@type": "Message",
      "@id": "urn:whatsapp-bridge:msg-1001",
      "name": "Olá!",
      "text": "Oi Alice, tudo bem por aí?",
      "dateSent": "2026-03-04T03:55:00Z",
      "sender": {
        "@type": "Person",
        "@id": "urn:refarm:identity:self",
        "name": "Me"
      },
      "recipient": {
        "@type": "Person",
        "@id": "urn:whatsapp-bridge:contact-alice-42"
      },
      "refarm:sourcePlugin": "whatsapp-bridge",
      "refarm:ingestedAt": "2026-03-04T04:00:00Z",
      "crdt:vectorClock": {
        "device-A": 8
      }
    },

    {
      "@comment": "Example 3 — The user's own Nostr identity node",
      "@type": "Person",
      "@id": "urn:refarm:identity:self",
      "name": "Refarm User",
      "nostr:publicKey": "npub1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "nostr:relays": [
        "wss://relay.damus.io",
        "wss://nos.lol"
      ],
      "refarm:sourcePlugin": "kernel",
      "refarm:ingestedAt": "2026-03-04T00:00:00Z"
    },

    {
      "@comment": "Example 4 — An installed plugin manifest node",
      "@type": "SoftwareApplication",
      "@id": "urn:nostr:event:abc123def456",
      "name": "WhatsApp Bridge",
      "softwareVersion": "1.0.0",
      "description": "Ingests WhatsApp messages and contacts into the sovereign graph",
      "applicationCategory": "Refarm Plugin",
      "downloadUrl": "https://cdn.example.com/plugins/whatsapp-bridge.wasm",
      "refarm:wasmHash": "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
      "refarm:pluginAuthor": {
        "@type": "Person",
        "nostr:publicKey": "npub1yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"
      },
      "refarm:nip89EventId": "abc123def456",
      "refarm:installedAt": "2026-03-04T01:00:00Z",
      "refarm:enabled": true,
      "refarm:sourcePlugin": "kernel"
    }
  ]
}
