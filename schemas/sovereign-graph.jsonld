      "image": "https://cdn.example.com/avatar/alice.jpg",
      "refarm:sourcePlugin": "matrix-bridge",
      "refarm:ingestedAt": "2026-03-04T04:00:00Z",
      "refarm:confidence": 0.95,
      "refarm:rawReference": {
        "@type": "refarm:RawCapture",
        "refarm:pluginPayload": {
          "matrix_id": "@alice:example.org",
          "displayname": "Alice Souza",
