      "refarm:schemaVersion": "0.1.0",
      "refarm:storageBackend": "SQLite/OPFS",
      "refarm:syncProtocol": "CRDT + Nostr"
    },
    {
      "@comment": "Example 1 — A contact ingested via a 'Matrix Bridge' plugin",
