  "@graph": [
    {
      "@type": "DataCatalog",
      "@id": "urn:refarm:sovereign-graph:v1",
      "name": "Refarm Sovereign Data Graph",
      "description": "The user's personal, portable, offline-first data graph. All nodes are normalised to JSON-LD before SQLite persistence, ensuring semantic interoperability across any platform.",
