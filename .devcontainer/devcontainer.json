{
  "name": "refarm-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "runArgs": [
    "--memory=4g",
    "--cpus=4",
    "--cap-add=SYS_ADMIN",
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined"
  ],
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "features": {
    "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode"
    }
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "UV_SYSTEM_PYTHON": "true",
    "UV_LINK_MODE": "copy",
    "RUSTUP_HOME": "/usr/local/rustup",
    "CARGO_HOME": "/usr/local/cargo",
    "CARGO_TERM_COLOR": "always",
    "NPM_CONFIG_PREFIX": "/home/vscode/.npm-global",
    "TURBO_CACHE_DIR": "/home/vscode/.turbo",
    "CARGO_BUILD_JOBS": "4",
    "CARGO_TARGET_DIR": "/home/vscode/.cargo-target",
    "LANG": "pt_BR.UTF-8",
    "LC_ALL": "pt_BR.UTF-8",
    "LANGUAGE": "pt_BR:pt:en",
    "TERM": "xterm-256color",
    "COLORTERM": "truecolor"
  },
  "remoteEnv": {
    "PNPM_HOME": "/home/vscode/.local/share/pnpm",
    "PATH": "/home/vscode/.local/share/pnpm:/home/vscode/.npm-global/bin:/home/vscode/.local/bin:${containerEnv:PATH}",
    "LANG": "pt_BR.UTF-8",
    "LC_ALL": "pt_BR.UTF-8",
    "LANGUAGE": "pt_BR:pt:en",
    "COLORTERM": "truecolor"
  },
  "mounts": [
    "source=refarm-pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume",
    "source=refarm-npm-global,target=/home/vscode/.npm-global,type=volume",
    "source=refarm-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=refarm-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=refarm-turbo-cache,target=/home/vscode/.turbo,type=volume",
    "source=refarm-playwright-cache,target=/home/vscode/.cache/ms-playwright,type=volume",
    "source=refarm-cargo-target,target=/home/vscode/.cargo-target,type=volume",
    "source=refarm-pi-home,target=/home/vscode/.pi,type=volume",
    "source=refarm-claude-home,target=/home/vscode/.claude,type=volume",
    "source=refarm-codex-home,target=/home/vscode/.codex,type=volume"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "nhoizey.gremlins",
        "arr.marksman",
        "MermaidChart.vscode-mermaid-chart",
        "DavidAnson.vscode-markdownlint",
        "ms-playwright.playwright"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "LANG": "pt_BR.UTF-8",
          "LC_ALL": "pt_BR.UTF-8",
          "LANGUAGE": "pt_BR:pt:en",
          "COLORTERM": "truecolor"
        },
        "rust-analyzer.lru.capacity": 44,
        "rust-analyzer.check.command": "check",
        "rust-analyzer.checkOnSave": false,
        "rust-analyzer.cargo.autoreload": false,
        "rust-analyzer.linkedProjects": [
          "./packages/heartwood/Cargo.toml",
          "./packages/tractor/Cargo.toml",
          "./packages/tractor/tests/fixtures/null-plugin/Cargo.toml"
        ]
      }
    }
  }
}
