{
  "name": "@refarm.dev/{{name}}",
  "version": "0.1.0",
  "private": {{privateStr}},
  "description": "{{description}}",
  "type": "module",
  "main": "./pkg/{{name}}.js",
  "types": "./pkg/{{name}}.js",
  "scripts": {
    "build:wasm": "node ../../scripts/ci/cargo-run.mjs --copy wasm32-wasip1/release/refarm_{{snakeCase name}}.wasm dist/refarm_{{snakeCase name}}.wasm component build --target wasm32-wasip1 --release",
    "build:transpile": "jco transpile dist/refarm_{{snakeCase name}}.wasm -o pkg --name {{name}}",
    "build": "npm run build:wasm && npm run build:transpile",
    "test": "node ../../scripts/ci/cargo-run.mjs test -- --test-threads=1"
  }
}
