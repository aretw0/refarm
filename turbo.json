{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "RUSTUP_HOME",
    "CARGO_HOME",
    "CARGO_TARGET_DIR",
    "RUSTUP_TOOLCHAIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".astro/**", "pkg/**", "target/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "*.config.*",
        "**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "env": ["VITEST_USE_DIST", "VITEST_FORCE_DIST"]
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "*.config.*",
        "**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "outputs": ["coverage/**"],
      "env": ["VITEST_USE_DIST", "VITEST_FORCE_DIST"]
    },
    "test:unit": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "*.config.*",
        "**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "env": ["VITEST_USE_DIST", "VITEST_FORCE_DIST"]
    },
    "test:integration": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "*.config.*",
        "**/*.rs",
        "Cargo.toml",
        "Cargo.lock"
      ],
      "env": ["VITEST_USE_DIST", "VITEST_FORCE_DIST"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "tests/**",
        "*.config.*",
        "playwright.config.*",
        "public/**"
      ],
      "outputs": ["test-results/**"]
    },
    "clean": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["build"]
    },
    "type-check:dist": {
      "dependsOn": ["build"]
    }
  }
}
