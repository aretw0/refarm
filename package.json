{
  "name": "refarm",
  "version": "0.0.0",
  "private": true,
  "description": "Refarm — Personal Operating System for sovereign data management",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:unit": "turbo run test:unit --",
    "test:integration": "vitest run '**/*.integration.test.ts' --passWithNoTests",
    "test:e2e": "node -e \"console.log('No E2E tests configured yet');\"",
    "coverage": "vitest run --coverage",
    "type-check": "turbo type-check",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "deps:check": "node scripts/check-deps.mjs",
    "deps:update": "node scripts/check-deps.mjs --update",
    "security:audit": "npm audit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "i18n:check": "node scripts/check-locales.mjs",
    "diagrams:check": "node scripts/check-diagrams.mjs",
    "diagrams:fix": "node scripts/check-diagrams.mjs --fix",
    "hooks:install": "node scripts/install-git-hooks.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.1",
    "jest": "^30.2.0",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.6.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22"
  }
}
