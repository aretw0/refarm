---
/**
 * Refarm Studio — Main Layout
 *
 * Provides the shared shell for all Studio pages.
 * Sets the required COOP/COEP headers (via astro.config.mjs) so that
 * SharedArrayBuffer (needed by WebContainers / sqlite-wasm) is available.
 */
interface Props {
  title?: string;
}

const { title = "Refarm Studio" } = Astro.props;
---

    <style is:global>
      @import "@refarm.dev/dsl-headless/src/tokens.css";
      @import "@refarm.dev/dsl-headless/src/styles.css";

      body {
        background: var(--refarm-bg-primary);
        color: var(--refarm-text-primary);
        font-family: var(--refarm-font-sans);
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      header {
        background: var(--refarm-glass-bg);
        backdrop-filter: var(--refarm-glass-blur);
        border-bottom: 1px solid var(--refarm-border-default);
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      header .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--refarm-text-primary);
        text-decoration: none;
      }

      header .logo span { color: var(--refarm-accent-primary); }

      nav {
        display: flex;
        gap: 1.5rem;
      }

      nav a {
        color: var(--refarm-text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      nav a:hover {
        color: var(--refarm-accent-primary);
      }

      main {
        flex: 1;
        padding: 2rem;
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
      }

      /* Plugin Lifecycle States */
      .plugin-view {
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
      }
      
      .plugin-view[data-refarm-state="hot"] {
        outline: 1px solid rgba(255, 152, 0, 0.5);
        box-shadow: 0 0 15px rgba(255, 152, 0, 0.1);
      }

      .plugin-view[data-refarm-state="throttled"] {
        opacity: 0.4;
        pointer-events: none;
        filter: grayscale(1) contrast(0.8);
        transform: scale(0.98);
      }

      .plugin-view[data-refarm-state="error"] {
        border: 1px dashed var(--refarm-accent-error, #f44336);
        background: rgba(244, 67, 54, 0.02);
      }

      /* Custom scrollbar to match the theme */
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: var(--refarm-bg-primary); }
      ::-webkit-scrollbar-thumb { background: var(--refarm-border-default); border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--refarm-text-muted); }
    </style>
  </head>
  <body>
    <div id="refarm-shell">
      <header id="refarm-header">
        <div id="refarm-slot-logo" class="slot">
           <a href={import.meta.env.BASE_URL} class="logo">🚜 <span>Refarm</span></a>
        </div>
        <nav id="refarm-slot-nav" class="slot">
          <a href={import.meta.env.BASE_URL}>Dashboard</a>
          <a href={`${import.meta.env.BASE_URL}plugins`}>Marketplace</a>
          <a href={`${import.meta.env.BASE_URL}graph`}>Graph</a>
          <a href={`${import.meta.env.BASE_URL}shed`}>The Shed</a>
        </nav>
      </header>
      
      <main id="refarm-main">
        <div id="refarm-slot-main" class="slot">
          <slot />
        </div>
      </main>

      <footer id="refarm-footer">
        <div id="refarm-slot-statusbar" class="slot">
          <span id="system-status">Refarm Studio Online</span>
          <span id="system-health" style="margin-left: 1rem; opacity: 0.8;">👤 100%</span>
        </div>
      </footer>
    </div>

    <style>
      #refarm-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1.5rem;
        background: var(--refarm-bg-secondary);
        border-bottom: 1px solid var(--refarm-border-default);
      }
      #refarm-main {
        flex: 1;
        padding: 2rem;
      }
      footer {
        padding: 0.5rem 1.5rem;
        background: var(--refarm-bg-elevated);
        border-top: 1px solid var(--refarm-border-default);
        font-size: 0.75rem;
        color: var(--refarm-text-secondary);
      }
      .slot {
        transition: opacity 0.3s ease;
      }
    </style>
  </body>
</html>
