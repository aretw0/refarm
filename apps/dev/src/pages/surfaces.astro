---
import Layout from "../layouts/Layout.astro";

const dashboardHref = import.meta.env.BASE_URL;
const streamsHref = `${import.meta.env.BASE_URL}streams`;
---

<Layout title="Surfaces — Refarm Studio">
  <section class="refarm-surface refarm-workbench surfaces-workbench" aria-labelledby="surface-workbench-title">
    <div class="refarm-eyebrow surfaces-workbench__eyebrow">Activation ledger</div>
    <div class="refarm-workbench-grid surfaces-workbench__grid">
      <div>
        <h1 id="surface-workbench-title" class="refarm-workbench-title surfaces-workbench__title">Surface trust graph</h1>
        <p class="refarm-workbench-lead">
          Inspect the Homestead activation path from manifest declaration to slot mount, including explicit render
          capability, slot allow-listing, kind allow-listing, and registry trust state.
        </p>
        <div class="refarm-cluster surfaces-workbench__actions">
          <a class="refarm-btn refarm-btn-primary refarm-btn-pill" href={dashboardHref}>Open live shell</a>
          <a class="refarm-btn refarm-btn-pill" href={streamsHref}>Stream workbench</a>
        </div>
      </div>
      <aside class="refarm-surface-card surfaces-workbench__card" aria-label="Surface activation gates">
        <strong>Activation gates</strong>
        <ol>
          <li><code class="refarm-code">slot</code> must exist in the current shell.</li>
          <li><code class="refarm-code">kind</code> must be supported by Homestead.</li>
          <li><code class="refarm-code">ui:panel:render</code> must be explicit.</li>
          <li>External plugins must be <code class="refarm-code">validated</code> or <code class="refarm-code">active</code>.</li>
        </ol>
      </aside>
    </div>
  </section>

  <section class="surfaces-ledger" aria-labelledby="surface-ledger-title">
    <div class="refarm-surface-card surfaces-ledger__panel surfaces-ledger__panel--primary">
      <div class="refarm-panel-header">
        <div>
          <p class="refarm-eyebrow">Live diagnostics</p>
          <h2 id="surface-ledger-title">Mounted and rejected Homestead surfaces</h2>
        </div>
        <span class="refarm-badge" data-refarm-surfaces-status>Booting</span>
      </div>
      <p class="refarm-card-body">
        This page boots a tiny diagnostics runtime: one internal trusted surface should mount, while one external
        unregistered surface should be rejected as <code class="refarm-code">untrusted-plugin</code>.
      </p>
      <div class="surfaces-ledger__inspector" data-refarm-surfaces-inspector-slot></div>
    </div>

    <div class="refarm-surface-card surfaces-ledger__panel">
      <p class="refarm-eyebrow">Expected proof</p>
      <ul class="surfaces-proof-list">
        <li><span class="refarm-badge">mount</span> <code class="refarm-code">studio-surface-diagnostics</code> in <code class="refarm-code">main</code></li>
        <li><span class="refarm-badge">reject</span> <code class="refarm-code">untrusted-plugin</code> with <code class="refarm-code">registry: unregistered</code></li>
        <li><span class="refarm-badge">audit</span> telemetry visible through Homestead inspector helpers</li>
      </ul>
    </div>
  </section>

  <style>
    .surfaces-workbench {
      margin-bottom: 1.5rem;
    }

    .surfaces-workbench__eyebrow {
      margin-bottom: 1rem;
      padding: 0.25rem 0.6rem;
      border: 1px solid rgba(35, 134, 54, 0.28);
      border-radius: 999px;
    }

    .surfaces-workbench__title {
      max-width: 10ch;
    }

    .surfaces-workbench__actions {
      margin-top: 1.5rem;
    }

    .surfaces-workbench__card {
      align-content: start;
      padding: 1.25rem;
    }

    .surfaces-workbench__card ol,
    .surfaces-proof-list {
      display: grid;
      gap: 0.65rem;
      margin: 0;
      padding-left: 1.1rem;
      color: var(--refarm-text-secondary);
    }

    .surfaces-ledger {
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.75fr);
      gap: 1rem;
      align-items: start;
    }

    .surfaces-ledger__panel {
      --refarm-card-padding: 1.25rem;
    }

    .surfaces-ledger__panel--primary {
      min-height: 18rem;
    }

    .surfaces-ledger__panel h2 {
      margin: 0.25rem 0 0;
      font-size: clamp(1.3rem, 3vw, 2rem);
      letter-spacing: -0.04em;
    }

    .surfaces-ledger__inspector {
      margin-top: 1rem;
    }

    .surfaces-proof-list {
      list-style: none;
      padding-left: 0;
    }

    .surfaces-proof-list li {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
    }

    @media (max-width: 860px) {
      .surfaces-ledger {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>

<script>
  import { OPFSSQLiteAdapter } from "@refarm.dev/storage-sqlite";
  import { LoroCRDTStorage, randomPeerId } from "@refarm.dev/sync-loro";
  import { Tractor } from "@refarm.dev/tractor";
  import { StudioShell } from "@refarm.dev/homestead/sdk";
  import { mountReactiveStudioSurfaceInspector } from "../lib/surface-inspector";

  function setStatus(text: string) {
    const status = document.querySelector<HTMLElement>("[data-refarm-surfaces-status]");
    if (status) status.textContent = text;
  }

  async function bootSurfaceDiagnostics() {
    const sqliteStorage = await new OPFSSQLiteAdapter().open(`refarm-surfaces-${Date.now()}`);
    const storage = new LoroCRDTStorage(sqliteStorage as any, randomPeerId());
    const identity = {
      id: "surface-diagnostics",
      getPublicKey: async () => "surface-diagnostics",
      sign: async (data: string) => data,
    };

    const tractor = await Tractor.boot({
      storage: storage as any,
      identity: identity as any,
      namespace: "studio-surfaces",
      envMetadata: {
        version: "0.1.0-solo-fertil",
        commit: "dev",
      },
    });

    tractor.plugins.registerInternal({
      id: "studio-surface-diagnostics",
      name: "Studio Surface Diagnostics",
      manifest: {
        id: "studio-surface-diagnostics",
        name: "Studio Surface Diagnostics",
        version: "0.1.0",
        entry: "internal:studio-surface-diagnostics",
        capabilities: {},
        extensions: {
          surfaces: [
            {
              layer: "homestead",
              kind: "panel",
              id: "surface-ledger-panel",
              slot: "main",
              capabilities: ["ui:panel:render"],
            },
          ],
        },
      } as any,
      call: async () => null,
      terminate: () => {},
      emitTelemetry: (event, payload) => tractor.emitTelemetry({ event, payload, pluginId: "studio-surface-diagnostics" }),
      state: "running",
    });

    tractor.plugins.registerInternal({
      id: "external-untrusted-surface",
      name: "External Untrusted Surface",
      manifest: {
        id: "external-untrusted-surface",
        name: "External Untrusted Surface",
        version: "0.1.0",
        entry: "./dist/untrusted-surface.mjs",
        capabilities: {},
        extensions: {
          surfaces: [
            {
              layer: "homestead",
              kind: "panel",
              id: "external-ledger-panel",
              slot: "main",
              capabilities: ["ui:panel:render"],
            },
          ],
        },
      } as any,
      call: async () => null,
      terminate: () => {},
      emitTelemetry: (event, payload) => tractor.emitTelemetry({ event, payload, pluginId: "external-untrusted-surface" }),
      state: "running",
    });

    const shell = new StudioShell(tractor);
    await shell.setup();

    const inspectorSlot = document.querySelector<HTMLElement>("[data-refarm-surfaces-inspector-slot]");
    if (inspectorSlot) {
      mountReactiveStudioSurfaceInspector(inspectorSlot, {
        telemetry: tractor,
        telemetryEvents: tractor.telemetry.dump(),
      });
    }
    setStatus("Ready");
  }

  bootSurfaceDiagnostics().catch((error) => {
    console.error("[studio/surfaces] Boot failed", error);
    setStatus("Boot failed");
    const inspectorSlot = document.querySelector<HTMLElement>("[data-refarm-surfaces-inspector-slot]");
    if (inspectorSlot) {
      const message = document.createElement("p");
      message.className = "refarm-card-body";
      message.textContent = `Surface diagnostics boot failed: ${(error as Error).message}`;
      inspectorSlot.replaceChildren(message);
    }
  });
</script>
