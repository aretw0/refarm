---
/**
 * Refarm Studio — Data Graph Explorer
 *
 * Visualises the sovereign JSON-LD nodes stored in the local SQLite database.
 */
import Layout from "../layouts/Layout.astro";
---

<Layout title="Data Graph — Refarm Studio">
  <div id="loading-overlay" class="loading-state">
    <div class="spinner"></div>
    <p>Loading Sovereign Graph...</p>
  </div>
</Layout>

<script>
  import { bootStudioRuntime } from "@refarm.dev/homestead/sdk/runtime";
  import { setupStudioShell } from "@refarm.dev/homestead/sdk/shell";

  async function boot() {
    try {
      // 1. Boot the shared Homestead runtime
      const { tractor } = await bootStudioRuntime({
        databaseName: `refarm-graph-${Date.now()}`,
        namespace: "studio-graph",
        identityId: "studio-graph",
        connectBrowserSync: true,
        tractorSync: true,
      });
      
      // 3. Handover to Shell Orchestrator
      await setupStudioShell(tractor);

      // 4. Hide loading
      document.getElementById("loading-overlay")?.remove();
      
    } catch (err) {
      console.error("[graph] Boot failed", err);
    }
  }

  boot();
</script>
