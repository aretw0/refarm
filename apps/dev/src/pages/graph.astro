---
/**
 * Refarm Studio — Data Graph Explorer
 *
 * Visualises the sovereign JSON-LD nodes stored in the local SQLite database.
 */
import Layout from "../layouts/Layout.astro";
---

<Layout title="Data Graph — Refarm Studio">
  <div id="loading-overlay" class="loading-state">
    <div class="spinner"></div>
    <p>Loading Sovereign Graph...</p>
  </div>
</Layout>

<script>
  import { LoroCRDTStorage, BrowserSyncClient, randomPeerId } from "@refarm.dev/sync-loro";
  import { Tractor } from "@refarm.dev/tractor";
  import { StudioShell } from "@refarm.dev/homestead/sdk";

  async function boot() {
    try {
      // 1. Initialize Adapters (Stubbed for now)
      const noop = {
        ensureSchema: async () => {},
        storeNode: async () => {},
        queryNodes: async () => [],
        execute: async () => {},
        query: async () => [],
        transaction: async (fn: () => Promise<unknown>) => fn(),
        close: async () => {}
      };
      const storage = new LoroCRDTStorage(noop as any, randomPeerId());
      new BrowserSyncClient(storage).connect();
      const identity = {};

      // 2. Boot Tractor
      const tractor = await Tractor.boot({ storage: storage as any, sync: storage, identity: identity as any, namespace: "studio-graph" });
      
      // 3. Handover to Shell Orchestrator
      const shell = new StudioShell(tractor);
      await shell.setup();

      // 4. Hide loading
      document.getElementById("loading-overlay")?.remove();
      
    } catch (err) {
      console.error("[graph] Boot failed", err);
    }
  }

  boot();
</script>
