---
/**
 * Refarm Studio — Plugin Marketplace
 *
 * Discovers plugins, e.g. via Nostr NIP-89 (kind:31990 events), and allows the user
 * to install them into the local Kernel sandbox.
 */
import Layout from "../layouts/Layout.astro";
---

<Layout title="Plugin Marketplace — Refarm Studio">
  <div id="loading-overlay" class="loading-state">
    <div class="spinner"></div>
    <p>Loading Plugin Marketplace...</p>
  </div>
</Layout>

<script>
  import { StudioShell } from "@refarm.dev/homestead/sdk";
  import {
    BrowserSyncClient,
    LoroCRDTStorage,
    randomPeerId,
  } from "@refarm.dev/sync-loro";
  import { Tractor } from "@refarm.dev/tractor";

  async function boot() {
    try {
      // 1. Initialize Adapters
      const noop = {
        ensureSchema: async () => {},
        storeNode: async () => {},
        queryNodes: async () => [],
        execute: async () => {},
        query: async () => [],
        transaction: async (fn: () => Promise<unknown>) => fn(),
        close: async () => {},
      };
      const storage = new LoroCRDTStorage(noop as any, randomPeerId());
      new BrowserSyncClient(storage).connect();
      const identity = {};

      // 2. Boot Tractor
      const tractor = await Tractor.boot({
        storage: storage as any,
        sync: storage,
        identity: identity as any,
        namespace: "studio-plugins",
      });

      // 3. Handover to Shell Orchestrator
      const shell = new StudioShell(tractor);
      await shell.setup();

      // 4. Hide loading
      document.getElementById("loading-overlay")?.remove();
    } catch (err) {
      console.error("[marketplace] Boot failed", err);
    }
  }

  boot();
</script>
