---
/**
 * Refarm Studio — Plugin Marketplace
 *
 * Discovers plugins, e.g. via Nostr NIP-89 (kind:31990 events), and allows the user
 * to install them into the local Kernel sandbox.
 */
import Layout from "../layouts/Layout.astro";
---

<Layout title="Plugin Marketplace — Refarm Studio">
  <div id="loading-overlay" class="loading-state">
    <div class="spinner"></div>
    <p>Loading Plugin Marketplace...</p>
  </div>
</Layout>

<script>
  import { bootStudioRuntime, StudioShell } from "@refarm.dev/homestead/sdk";

  async function boot() {
    try {
      // 1. Boot the shared Homestead runtime
      const { tractor } = await bootStudioRuntime({
        databaseName: `refarm-plugins-${Date.now()}`,
        namespace: "studio-plugins",
        identityId: "studio-plugins",
        connectBrowserSync: true,
        tractorSync: true,
      });

      // 3. Handover to Shell Orchestrator
      const shell = new StudioShell(tractor);
      await shell.setup();

      // 4. Hide loading
      document.getElementById("loading-overlay")?.remove();
    } catch (err) {
      console.error("[marketplace] Boot failed", err);
    }
  }

  boot();
</script>
