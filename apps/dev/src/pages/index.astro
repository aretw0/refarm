---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Dashboard — Refarm Studio">
  <div id="loading-overlay" class="loading-state">
    <div class="spinner"></div>
    <p>Initializing Sovereign Environment...</p>
  </div>

  <style>
    .loading-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 40vh;
      color: var(--refarm-text-secondary);
      font-family: var(--refarm-font-mono);
    }
    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid var(--refarm-bg-elevated);
      border-top: 3px solid var(--refarm-accent-primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-bottom: 1rem;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  </style>
</Layout>

<script>
  import {
    bootStudioDashboardWorkbench,
    renderStudioDashboardBootFailure,
  } from "../lib/studio-dashboard-runtime";

  bootStudioDashboardWorkbench({
    baseUrl: import.meta.env.BASE_URL,
  }).catch((error) => {
    console.error("[homestead] Boot failed", error);
    renderStudioDashboardBootFailure(error);
  });
</script>
