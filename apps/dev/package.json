{
  "name": "@refarm.dev/app",
  "version": "0.1.0",
  "description": "Refarm Dev App — in-browser IDE for developing, testing and publishing Refarm plugins",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro:check": "astro check",
    "lint": "npm run astro:check && tsc --build && tsc --noEmit",
    "type-check": "npm run astro:check && tsc --project tsconfig.json --noEmit",
    "type-check:dist": "npm run astro:check && tsc --project tsconfig.build.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@refarm.dev/sower": "*",
    "@refarm.dev/scarecrow": "*",
    "@refarm.dev/sync-loro": "*",
    "@refarm.dev/tractor": "*",
    "@refarm.me/identity-nostr": "*",
    "@refarm.dev/storage-sqlite": "*",
    "@refarm.dev/ds": "*",
    "@refarm.dev/homestead": "*",
    "astro": "^6.1.8"
  },
  "devDependencies": {
    "@refarm.dev/config": "*",
    "typescript": "^6.0.3",
    "@refarm.dev/tsconfig": "*"
  },
  "license": "MIT"
}
