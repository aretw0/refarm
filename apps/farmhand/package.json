{
  "name": "@refarm.dev/farmhand",
  "version": "0.1.0",
  "description": "Refarm Farmhand — headless Node.js daemon for always-on sync",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@refarm.dev/effort-contract-v1": "*",
    "@refarm.dev/file-stream-transport": "*",
    "@refarm.dev/identity-contract-v1": "*",
    "@refarm.dev/plugin-manifest": "*",
    "@refarm.dev/sse-stream-transport": "*",
    "@refarm.dev/storage-contract-v1": "*",
    "@refarm.dev/stream-contract-v1": "*",
    "@refarm.dev/sync-loro": "*",
    "@refarm.dev/tractor": "*",
    "@refarm.dev/ws-stream-transport": "*",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "license": "AGPL-3.0-only"
}
