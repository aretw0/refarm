{
	"name": "@refarm.dev/farmhand",
	"version": "0.1.0",
	"description": "Refarm Farmhand — headless Node.js daemon for always-on sync",
	"type": "module",
	"main": "./dist/index.js",
	"scripts": {
		"start": "node --experimental-strip-types --experimental-transform-types --import ../../scripts/farmhand-node-register-loader.mjs src/index.ts",
		"dev": "node --watch --experimental-strip-types --experimental-transform-types --import ../../scripts/farmhand-node-register-loader.mjs src/index.ts",
		"build": "tsc --project tsconfig.build.json",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:unit": "vitest run",
		"lint": "eslint src"
	},
	"dependencies": {
		"@refarm.dev/config": "workspace:*",
		"@refarm.dev/effort-contract-v1": "workspace:*",
		"@refarm.dev/file-stream-transport": "workspace:*",
		"@refarm.dev/identity-contract-v1": "workspace:*",
		"@refarm.dev/pi-agent": "workspace:*",
		"@refarm.dev/plugin-manifest": "workspace:*",
		"@refarm.dev/silo": "workspace:*",
		"@refarm.dev/sse-stream-transport": "workspace:*",
		"@refarm.dev/storage-contract-v1": "workspace:*",
		"@refarm.dev/storage-sqlite": "workspace:*",
		"@refarm.dev/stream-contract-v1": "workspace:*",
		"@refarm.dev/sync-loro": "workspace:*",
		"@refarm.dev/task-contract-v1": "workspace:*",
		"@refarm.dev/tractor": "workspace:*",
		"@refarm.dev/ws-stream-transport": "workspace:*",
		"ws": "catalog:"
	},
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@types/node": "catalog:",
		"@types/ws": "catalog:",
		"@refarm.dev/vtconfig": "workspace:*",
		"typescript": "catalog:",
		"@refarm.dev/deps": "workspace:*"
	},
	"license": "AGPL-3.0-only"
}