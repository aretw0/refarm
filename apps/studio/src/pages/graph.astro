---
/**
 * Refarm Studio — Data Graph Explorer
 *
 * Visualises the sovereign JSON-LD nodes stored in the local SQLite database.
 */
import Layout from "../layouts/Layout.astro";
---

<Layout title="Data Graph — Refarm Studio">
  <section style="max-width: 1000px; margin: 0 auto;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.25rem;">🗄️ Sovereign Data Graph</h2>
    <p style="color: #8b949e; margin-bottom: 1.5rem;">
      All data stored locally in SQLite/OPFS, normalised as JSON-LD nodes.
    </p>

    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
      <input
        id="type-filter"
        type="text"
        placeholder="Filter by @type (e.g. Person)"
        style="
          flex: 1;
          background: #0d1117;
          border: 1px solid #30363d;
          border-radius: 6px;
          padding: 0.5rem 0.75rem;
          color: #c9d1d9;
          font-size: 0.875rem;
        "
      />
      <button id="query-btn" style="
        background: #1f6feb;
        border: none;
        border-radius: 6px;
        padding: 0.5rem 1rem;
        color: #fff;
        cursor: pointer;
        font-size: 0.875rem;
      ">
        Query
      </button>
    </div>

    <div id="graph-results" style="font-family: monospace; font-size: 0.8rem;">
      <p style="color: #8b949e;">Enter a type and click Query to browse your data.</p>
    </div>
  </section>
</Layout>

<script>
  document.getElementById("query-btn")?.addEventListener("click", async () => {
    const type = (document.getElementById("type-filter") as HTMLInputElement).value.trim() || "Person";
    const resultsEl = document.getElementById("graph-results")!;

    resultsEl.innerHTML = `<p style="color: #8b949e;">Loading…</p>`;

    try {
      const { Kernel } = await import("@refarm/kernel");
      const kernel = await Kernel.boot({ dbName: "refarm-studio" });
      const nodes = await kernel.queryNodes(type);
      await kernel.shutdown();

      if (nodes.length === 0) {
        resultsEl.innerHTML = `<p style="color: #8b949e;">No nodes of type "${type}" found.</p>`;
        return;
      }

      resultsEl.innerHTML = nodes
        .map(
          (n) => `
          <pre style="
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 6px;
            padding: 1rem;
            margin-bottom: 0.75rem;
            overflow-x: auto;
            white-space: pre-wrap;
            word-break: break-word;
          ">${JSON.stringify(n, null, 2)}</pre>
        `
        )
        .join("");
    } catch (err) {
      resultsEl.innerHTML = `<p style="color: #f85149;">Error: ${(err as Error).message}</p>`;
    }
  });
</script>
