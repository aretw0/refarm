{
	"name": "@refarm.me/app",
	"version": "0.1.0",
	"description": "Refarm.me — The Sovereign Citizen Hub",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro:check": "astro check",
		"type-check": "astro check && tsc --project tsconfig.json --noEmit",
		"type-check:dist": "astro check && tsc --project tsconfig.build.json --noEmit",
		"test:unit": "vitest run",
		"test": "vitest run",
		"smoke:sync": "node scripts/smoke-browser-sync-status.mjs",
		"smoke:plugin-cache": "node scripts/smoke-plugin-cache.mjs",
		"smoke:content-plugin": "node scripts/smoke-content-plugin.mjs",
		"smoke:pwa": "node scripts/smoke-pwa.mjs",
		"lint": "eslint src"
	},
	"dependencies": {
		"@refarm.dev/homestead": "workspace:*",
		"@refarm.dev/runtime": "workspace:*",
		"@refarm.dev/storage-sqlite": "workspace:*",
		"@refarm.dev/sync-loro": "workspace:*",
		"@refarm.dev/tractor": "workspace:*",
		"astro": "^6.4.8"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@playwright/test": "^1.60.0",
		"@refarm.dev/config": "workspace:*",
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"typescript": "catalog:"
	},
