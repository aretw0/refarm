{
	"extends": "@refarm.dev/tsconfig/dom.json",
	"compilerOptions": {
		"noEmit": true,
		"outDir": "./dist",
		"baseUrl": ".",
		"rootDir": "../..",
		"paths": {
			"@refarm.dev/tractor": ["../../packages/tractor/src/index.ts"],
			"@refarm.dev/homestead": ["../../packages/homestead/src/index.ts"],
			"@refarm.dev/homestead/ui": ["../../packages/homestead/src/ui/index.ts"],
			"@refarm.dev/homestead/sdk": ["../../packages/homestead/src/sdk/index.ts"],
			"@refarm.dev/homestead/sdk/runtime": [
				"../../packages/homestead/src/sdk/runtime.ts"
			],
			"@refarm.dev/homestead/sdk/surface-inspector": [
				"../../packages/homestead/src/sdk/surface-inspector.ts"
			]
		}
	},
	"exclude": ["node_modules", "dist"],
	"include": ["src/**/*", ".astro/types.d.ts"]
}
