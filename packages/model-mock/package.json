{
	"name": "@refarm.dev/model-mock",
	"version": "0.1.0",
	"description": "OpenAI-compatible mock HTTP server for testing agent loops without real LLM calls",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --project tsconfig.build.json --watch",
		"lint": "eslint src",
		"type-check": "tsc --noEmit",
		"type-check:dist": "tsc --project tsconfig.build.json --noEmit",
		"test": "vitest run",
		"test:unit": "vitest run",
		"clean": "rm -rf dist"
	},
	"keywords": ["mock", "model", "openai", "test", "harness", "agent"],
	"author": "Refarm Contributors",
	"license": "MIT",
	"files": ["dist", "README.md"],
	"publishConfig": { "access": "public" },
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
