{
	"name": "@refarm.dev/tractor",
	"scaffold": {
		"type": "exempt",
		"reason": "rootDir set to '..' to include generated Rust bindings from sibling tractor crate; dist/src/ output path is intentional"
	},
	"version": "0.1.0",
	"description": "Refarm Tractor \u2014 the heavy machinery that cultivates your personal 'Solo F\u00e9rtil' orchestrating plugins",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/aretw0/refarm.git",
		"directory": "packages/tractor-ts"
	},
	"bugs": {
		"url": "https://github.com/aretw0/refarm/issues"
	},
	"homepage": "https://refarm.dev.br",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"exports": {
		".": {
			"browser": "./dist/src/index.browser.js",
			"node": "./dist/src/index.js",
			"import": "./dist/src/index.js",
			"types": "./dist/src/index.d.ts"
		},
		"./test/test-utils": {
			"types": "./dist/test/test-utils.d.ts",
			"default": "./dist/test/test-utils.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --project tsconfig.build.json --watch",
		"lint": "eslint src",
		"type-check": "tsc --project tsconfig.json --noEmit",
		"type-check:dist": "tsc --project tsconfig.build.json --noEmit",
		"test": "npm run test:unit",
		"test:unit": "vitest run",
		"coverage:save": "vitest run --coverage && cp coverage/coverage-summary.json benchmarks/coverage-baseline.json",
		"coverage:check": "vitest run --coverage && node scripts/check-coverage.mjs",
		"bench": "vitest bench test/stress.bench.ts",
		"bench:save": "vitest bench test/stress.bench.ts --run --outputJson benchmarks/baseline.json && node scripts/sanitize-bench.mjs benchmarks/baseline.json",
		"bench:compare": "vitest bench test/stress.bench.ts --run --compare benchmarks/baseline.json",
		"bench:check": "vitest bench test/stress.bench.ts --run --outputJson benchmarks/current.json && node scripts/sanitize-bench.mjs benchmarks/current.json && node scripts/check-benchmarks.mjs",
		"clean": "rm -rf dist",
		"runtime-module:descriptor": "node scripts/generate-browser-runtime-module-descriptor.mjs",
		"runtime-module:verify": "node scripts/verify-browser-runtime-module-descriptor.mjs",
		"runtime-module:smoke": "node scripts/smoke-browser-runtime-module-descriptor.mjs",
		"runtime-module:ci": "npm run runtime-module:smoke"
	},
	"dependencies": {
		"@bytecodealliance/jco": "^1.18.0",
		"@bytecodealliance/preview2-shim": "^0.17.3",
		"@noble/ed25519": "^3.1.0",
		"@refarm.dev/identity-contract-v1": "workspace:*",
		"@refarm.dev/plugin-manifest": "workspace:*",
		"@refarm.dev/registry": "workspace:*",
		"@refarm.dev/storage-contract-v1": "workspace:*",
		"@refarm.dev/sync-contract-v1": "workspace:*"
	},
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/hello-world-plugin": "workspace:*",
		"@refarm.dev/pi-agent": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*",
		"nostr-tools": "^2.23.3"
	},
	"license": "AGPL-3.0-only",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	]
}
