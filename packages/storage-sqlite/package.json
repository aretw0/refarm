{
  "name": "@refarm.dev/storage-sqlite",
  "version": "0.1.0",
  "description": "Sovereign SQLite/OPFS storage primitive — usable independently of Refarm",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/refarm-dev/refarm.git",
    "directory": "packages/storage-sqlite"
  },
  "bugs": {
    "url": "https://github.com/refarm-dev/refarm/issues"
  },
  "homepage": "https://refarm.dev.br",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "type-check:dist": "tsc --project tsconfig.build.json --noEmit",
    "test:conformance": "vitest run src/storage-v1.conformance.test.ts",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "sqlite",
    "opfs",
    "offline-first",
    "local-first",
    "wasm"
  ],
  "dependencies": {
    "@refarm.dev/storage-contract-v1": "*"
  }
}
