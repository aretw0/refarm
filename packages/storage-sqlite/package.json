{
	"name": "@refarm.dev/storage-sqlite",
	"version": "0.1.0",
	"description": "Sovereign SQLite/OPFS storage primitive \u2014 usable independently of Refarm",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/aretw0/refarm.git",
		"directory": "packages/storage-sqlite"
	},
	"bugs": {
		"url": "https://github.com/aretw0/refarm/issues"
	},
	"homepage": "https://refarm.dev.br",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./node": {
			"import": "./dist/node.js",
			"types": "./dist/node.d.ts"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --project tsconfig.build.json --watch",
		"lint": "eslint src",
		"type-check": "tsc --noEmit",
		"type-check:dist": "tsc --project tsconfig.build.json --noEmit",
		"test": "vitest run",
		"test:conformance": "vitest run src/storage-v1.conformance.test.ts src/task-v1.conformance.test.ts src/session-v1.conformance.test.ts",
		"test:unit": "vitest run test/smoke.test.ts",
		"coverage:save": "vitest run --coverage && cp coverage/coverage-summary.json benchmarks/coverage-baseline.json",
		"coverage:check": "vitest run --coverage && node scripts/check-coverage.mjs",
		"clean": "rm -rf dist"
	},
	"keywords": [
		"sqlite",
		"opfs",
		"offline-first",
		"local-first",
		"wasm"
	],
	"dependencies": {
		"@refarm.dev/storage-contract-v1": "workspace:*",
		"@refarm.dev/task-contract-v1": "workspace:*",
		"@refarm.dev/session-contract-v1": "workspace:*"
	},
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*"
	}
}
