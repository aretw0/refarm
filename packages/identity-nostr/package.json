{
  "name": "@refarm/identity-nostr",
  "version": "0.1.0",
  "description": "Nostr identity primitive — keypair management, NIP-89/94 plugin discovery, usable independently",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "clean": "rm -rf dist"
  },
  "keywords": ["nostr", "nip-89", "nip-94", "identity", "decentralized", "sovereign"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
