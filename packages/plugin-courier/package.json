{
	"name": "@refarm.dev/plugin-courier",
	"version": "0.1.0",
	"description": "Graph-native Web Publisher Plugin (The Courier) for Refarm.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"type-check": "tsc --noEmit",
		"type-check:dist": "tsc --project tsconfig.build.json --noEmit",
		"test": "pnpm run type-check && vitest run",
		"lint": "eslint src"
	},
	"dependencies": {
		"@refarm.dev/runtime": "workspace:*"
	},
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/tractor": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	}
}
