{
	"name": "@refarm.dev/ds",
	"version": "0.1.0",
	"description": "Refarm Design System — Shared Styles and Tokens",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/index.js",
		"dist/index.js.map",
		"dist/index.d.ts",
		"dist/index.d.ts.map",
		"dist/contract.js",
		"dist/contract.js.map",
		"dist/contract.d.ts",
		"dist/contract.d.ts.map",
		"dist/theme-conformance.js",
		"dist/theme-conformance.js.map",
		"dist/theme-conformance.d.ts",
		"dist/theme-conformance.d.ts.map",
		"src/*.css",
		"src/themes/*.css"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./tokens.css": "./src/tokens.css",
		"./components.css": "./src/components.css",
		"./tailwind-bridge.css": "./src/tailwind-bridge.css",
		"./themes/*": "./src/themes/*",
		"./styles/*": "./src/*"
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"lint": "eslint src"
	},
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-links": "^10.3.5",
		"@storybook/html": "^10.3.5",
		"@storybook/html-vite": "^10.3.5",
		"storybook": "^10.3.5",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	}
}
