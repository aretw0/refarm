{
  "name": "@refarm.dev/sync-loro",
  "version": "0.1.0",
  "description": "Loro CRDT engine for Refarm \u2014 implements SyncAdapter + StorageAdapter via CQRS (LoroDoc write model, SQL read model). See ADR-045.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/aretw0/refarm.git",
    "directory": "packages/sync-loro"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:conformance": "vitest run src/sync-v1.conformance.test.ts",
    "clean": "rm -rf dist",
    "lint": "eslint src"
  },
  "dependencies": {
    "loro-crdt": "^1.11.0",
    "@refarm.dev/sync-contract-v1": "workspace:*",
    "@refarm.dev/storage-contract-v1": "workspace:*"
  },
  "devDependencies": {
    "@refarm.dev/eslint-config": "workspace:*",
    "@refarm.dev/storage-memory": "workspace:*",
    "@refarm.dev/tsconfig": "workspace:*"
  },
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
