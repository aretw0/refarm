{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://refarm.dev/schemas/release-output.schema.json",
  "title": "Refarm Release Engine CLI JSON Output",
  "oneOf": [
    { "$ref": "#/$defs/planOutput" },
    { "$ref": "#/$defs/checkOutput" },
    { "$ref": "#/$defs/gatesOutput" }
  ],
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "schemaVersion",
        "status",
        "packageCount",
        "packages",
        "blockers",
        "packageProfiles",
        "requiredGates",
        "providers",
        "profileTags",
        "selection",
        "ok",
        "dryRun",
        "command"
      ],
      "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "status": { "type": "string" },
        "packageCount": { "type": "integer", "minimum": 0 },
        "packages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "object" }
        },
        "acceptance": { "$ref": "#/$defs/acceptance" },
        "packageProfiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/packageProfileSummary" }
        },
        "requiredGates": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "providers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "profileTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selection": {
          "anyOf": [
            { "$ref": "#/$defs/selectionSummary" },
            { "type": "null" }
          ]
        },
        "ok": { "type": "boolean" },
        "dryRun": { "type": "boolean" },
        "command": { "enum": ["plan", "check", "gates"] },
        "auditRecord": { "$ref": "#/$defs/auditRecord" }
      }
    },
    "auditRecord": {
      "type": "object",
      "required": ["schemaVersion", "createdAt", "digest", "payload"],
      "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "createdAt": { "type": "string", "minLength": 1 },
        "digest": {
          "type": "object",
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "const": "sha256" },
            "value": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "additionalProperties": false
        },
        "payload": {
          "type": "object",
          "required": [
            "schemaVersion",
            "releaseOutputSchemaVersion",
            "ok",
            "status",
            "policyVersion",
            "mode",
            "packageCount",
            "packages",
            "blockers",
            "packageProfiles",
            "requiredGates",
            "gates",
            "publishIntents",
            "profileTags",
            "selection",
            "dryRun"
          ],
          "properties": {
            "schemaVersion": { "type": "integer", "const": 1 },
            "releaseOutputSchemaVersion": { "type": "integer", "const": 1 },
            "ok": { "type": "boolean" },
            "status": { "type": "string" },
            "policyVersion": {
              "anyOf": [
                { "type": "string" },
                { "type": "null" }
              ]
            },
            "mode": {
              "anyOf": [
                { "enum": ["changeset", "tagged", "hybrid"] },
                { "type": "null" }
              ]
            },
            "packageCount": { "type": "integer", "minimum": 0 },
            "packages": {
              "type": "array",
              "items": { "type": "string" }
            },
            "blockers": {
              "type": "array",
              "items": { "type": "object" }
            },
            "acceptance": { "$ref": "#/$defs/acceptance" },
            "packageProfiles": {
              "type": "array",
              "items": { "$ref": "#/$defs/packageProfileSummary" }
            },
            "requiredGates": {
              "type": "array",
              "items": { "type": "string" }
            },
            "gates": {
              "type": "array",
              "items": { "type": "object" }
            },
            "publishIntents": {
              "type": "array",
              "items": { "type": "object" }
            },
            "profileTags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "selection": {
              "anyOf": [
                { "$ref": "#/$defs/selectionSummary" },
                { "type": "null" }
              ]
            },
            "dryRun": { "type": "boolean" }
          }
        }
      }
    },
    "selectionSummary": {
      "type": "object",
      "required": ["id", "description", "audienceBoundary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "audienceBoundary": {
          "anyOf": [
            { "$ref": "#/$defs/audienceBoundary" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "audienceBoundary": {
      "type": "object",
      "required": ["consumer", "naming", "productLocal"],
      "properties": {
        "consumer": { "type": "string", "minLength": 1 },
        "naming": { "type": "string", "minLength": 1 },
        "productLocal": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "acceptance": {
      "type": "object",
      "required": [
        "status",
        "packageCount",
        "blockerCount",
        "requiredGateCount",
        "requiredCheckCount",
        "providerCount",
        "manualApprovalRequired",
        "surfaces",
        "profileTags",
        "requiredChecks"
      ],
      "properties": {
        "status": { "enum": ["accepted", "blocked"] },
        "packageCount": { "type": "integer", "minimum": 0 },
        "blockerCount": { "type": "integer", "minimum": 0 },
        "requiredGateCount": { "type": "integer", "minimum": 0 },
        "requiredCheckCount": { "type": "integer", "minimum": 0 },
        "providerCount": { "type": "integer", "minimum": 0 },
        "manualApprovalRequired": { "type": "boolean" },
        "surfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profileTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredChecks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "package"],
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "package": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "packageProfileSummary": {
      "type": "object",
      "required": ["id", "risk", "surface", "tags", "mustPassChecks"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "risk": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "surface": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustPassChecks": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "gateResult": {
      "type": "object",
      "required": ["ok", "results", "policy", "dryRun"],
      "properties": {
        "ok": { "type": "boolean" },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/gateCommandResult" }
        },
        "policy": { "type": "object" },
        "dryRun": { "type": "boolean" },
        "blockedBy": { "type": "object" },
        "phase": { "type": "string" },
        "command": { "type": "string" },
        "reason": { "type": "string" },
        "blockers": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "gateCommandResult": {
      "type": "object",
      "required": ["phase", "phaseName", "command", "status", "stdout", "stderr", "code"],
      "properties": {
        "phase": { "type": "string", "minLength": 1 },
        "phaseName": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "status": { "enum": ["passed", "failed", "skipped"] },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "code": { "type": "integer" },
        "signal": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "dryRun": { "type": "boolean" }
      }
    },
    "planOutput": {
      "allOf": [
        { "$ref": "#/$defs/summary" },
        {
          "type": "object",
          "required": ["gates", "publishIntents"],
          "properties": {
            "command": { "const": "plan" },
            "gates": {
              "type": "array",
              "items": { "type": "object" }
            },
            "publishIntents": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      ]
    },
    "checkOutput": {
      "allOf": [
        { "$ref": "#/$defs/summary" },
        {
          "type": "object",
          "required": ["gateResult", "commandNote"],
          "properties": {
            "command": { "const": "check" },
            "gateResult": { "$ref": "#/$defs/gateResult" },
            "commandNote": { "type": "string" }
          }
        }
      ]
    },
    "gatesOutput": {
      "allOf": [
        { "$ref": "#/$defs/summary" },
        {
          "type": "object",
          "required": ["gateResult"],
          "properties": {
            "command": { "const": "gates" },
            "gateResult": { "$ref": "#/$defs/gateResult" }
          }
        }
      ]
    }
  }
}
