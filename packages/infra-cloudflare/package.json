{
  "name": "@refarm.dev/infra-cloudflare",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare provider — agnostic primitives and provider adapters for managing Cloudflare resources",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit && tsc --noEmit --project tsconfig.worker.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@refarm.dev/infra-contract-v1": "*",
    "@refarm.dev/infra-turbo-cache": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@refarm.dev/tsconfig": "*",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.90.0"
  }
}
