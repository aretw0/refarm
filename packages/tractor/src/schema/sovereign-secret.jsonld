{
  "@context": {
    "refarm": "https://refarm.dev.br/ontology#",
    "schema": "https://schema.org/",
    "SovereignSecret": "refarm:SovereignSecret",
    "tier": "refarm:securityTier",
    "anchor": "refarm:hardwareAnchor",
    "jwe": "refarm:encryptedPayload",
    "hint": "schema:description",
    "timestamp": "schema:dateModified"
  },
  "@type": "SovereignSecret",
  "@id": "urn:refarm:secret:{uuid}",
  "timestamp": "{ISO_DATE}",
  "tier": "gold | silver | bronze",
  "anchor": "webauthn | passkey | password | none",
  "hint": "Optional human-readable reminder of what this secret is",
  "jwe": {
    "protected": "...",
    "encrypted_key": "...",
    "iv": "...",
    "ciphertext": "...",
    "tag": "..."
  }
}
