{
  "name": "@refarm.dev/tractor",
  "version": "0.1.0",
  "description": "Refarm Tractor — the heavy machinery that cultivates your personal 'Solo Fértil' orchestrating plugins",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/refarm-dev/refarm.git",
    "directory": "packages/tractor"
  },
  "bugs": {
    "url": "https://github.com/refarm-dev/refarm/issues"
  },
  "homepage": "https://refarm.dev.br",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test/test-utils": {
      "types": "./test/test-utils.ts",
      "default": "./test/test-utils.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "tsc --project tsconfig.json --noEmit",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "bench": "vitest bench test/stress.bench.ts",
    "bench:save": "vitest bench test/stress.bench.ts --run --outputJson benchmarks/baseline.json && node scripts/sanitize-bench.mjs benchmarks/baseline.json",
    "bench:compare": "vitest bench test/stress.bench.ts --run --compare benchmarks/baseline.json",
    "bench:check": "vitest bench test/stress.bench.ts --run --outputJson benchmarks/current.json && node scripts/sanitize-bench.mjs benchmarks/current.json && node scripts/check-benchmarks.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bytecodealliance/jco": "^1.4.0",
    "@refarm.dev/identity-contract-v1": "*",
    "@refarm.dev/plugin-manifest": "*",
    "@refarm.dev/storage-contract-v1": "*",
    "@refarm.dev/sync-contract-v1": "*"
  },
  "devDependencies": {
    "@noble/ed25519": "^3.0.0",
    "@refarm.dev/tsconfig": "*",
    "nostr-tools": "^2.23.3",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
