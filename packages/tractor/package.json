{
	"name": "@refarm.dev/tractor-rs",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "node ../../scripts/ci/cargo-run.mjs build --release",
		"test": "node ../../scripts/ci/cargo-run.mjs test --lib && node ../../scripts/ci/cargo-run.mjs test --test ws_integration",
		"lint": "node ../../scripts/ci/cargo-run.mjs clippy -- -D warnings",
		"lint:prepush": "node ../../scripts/ci/cargo-run.mjs clippy --lib -- -D warnings",
		"test:unit": "node ../../scripts/ci/cargo-run.mjs test --lib",
		"test:sidecar": "node ../../scripts/ci/cargo-run.mjs test --lib sidecar_ --quiet",
		"test:prepush": "node ../../scripts/ci/cargo-run.mjs test --lib --quiet",
		"test:smoke:ws": "node ../../scripts/ci/cargo-run.mjs test --test ws_integration ws_server_accepts_connection -- --exact --nocapture",
		"test:smoke:health": "node ../../scripts/ci/cargo-run.mjs test --bin tractor runtime_boot_probe_succeeds_in_memory_namespace -- --nocapture && node ../../scripts/ci/cargo-run.mjs test --bin tractor ws_probe_succeeds_when_daemon_is_listening -- --nocapture",
		"test:integration": "node ../../scripts/ci/cargo-run.mjs test --test ws_integration ws_server_accepts_connection -- --exact --nocapture",
		"bench:save": "node ../../scripts/ci/cargo-run.mjs run --release --bin tractor-bench -- save",
		"bench:check": "node ../../scripts/ci/cargo-run.mjs run --release --bin tractor-bench -- check",
		"coverage:save": "node scripts/coverage.mjs save",
		"coverage:check": "node scripts/coverage.mjs check"
	}
}
