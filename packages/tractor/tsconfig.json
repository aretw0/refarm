{
  "extends": "@refarm.dev/tsconfig/node.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@refarm.dev/tractor": ["./src/index.ts"],
      "@refarm.dev/storage-contract-v1": ["../storage-contract-v1/src/index.ts"],
      "@refarm.dev/sync-contract-v1": ["../sync-contract-v1/src/index.ts"],
      "@refarm.dev/identity-contract-v1": ["../identity-contract-v1/src/index.ts"],
      "@refarm.dev/plugin-manifest": ["../plugin-manifest/src/index.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
