{
	"name": "@refarm.dev/silo",
	"version": "0.1.0",
	"description": "The Silo — provider-neutral context and secret provisioner.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"node": "./dist/index.js",
			"browser": "./dist/index.browser.js",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./collect": {
			"import": "./dist/collect.js",
			"types": "./dist/collect.d.ts"
		},
		"./key-manager": {
			"import": "./dist/key-manager.js",
			"types": "./dist/key-manager.d.ts"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --project tsconfig.build.json --watch",
		"test": "vitest run",
		"lint": "eslint src"
	},
	"optionalDependencies": {
		"@refarm.dev/heartwood": "workspace:*"
	},
	"license": "AGPL-3.0-only",
	"files": [
		"README.md",
		"ROADMAP.md",
		"dist/index.js",
		"dist/index.d.ts",
		"dist/index.browser.js",
		"dist/index.browser.d.ts",
		"dist/collect.js",
		"dist/collect.d.ts",
		"dist/key-manager.js",
		"dist/key-manager.d.ts"
	],
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@refarm.dev/deps": "workspace:*",
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/prompt-contract-v1": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*"
	}
}
