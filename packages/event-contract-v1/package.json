{
	"name": "@refarm.dev/event-contract-v1",
	"version": "0.1.0",
	"private": true,
	"description": "Provider-neutral event bus contract — emit/subscribe primitives for cross-extension communication",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --project tsconfig.build.json --watch",
		"lint": "eslint src",
		"type-check": "tsc --noEmit",
		"type-check:dist": "tsc --project tsconfig.build.json --noEmit",
		"test": "vitest run",
		"test:unit": "vitest run src/conformance.test.ts",
		"test:conformance": "vitest run src/conformance.test.ts",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"@refarm.dev/eslint-config": "workspace:*",
		"@refarm.dev/tsconfig": "workspace:*",
		"@refarm.dev/vtconfig": "workspace:*"
	}
}
