{
	"extends": [
		"./tsconfig.json",
		"@refarm.dev/tsconfig/build.json"
	],
	"compilerOptions": {
		"rootDir": "src",
		"composite": true,
		"outDir": "dist",
		"paths": {
			"@refarm.dev/tractor": [
				"packages/tractor-ts/dist/src/index.d.ts"
			]
		}
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"src/**/*.test.ts",
		"node_modules",
		"dist"
	]
}
