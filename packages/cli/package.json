{
  "name": "@refarm.dev/cli",
  "version": "0.1.0",
  "description": "Refarm CLI — The command-line interface for the Sovereign Farm.",
  "type": "module",
  "bin": {
    "refarm": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@refarm.dev/fence": "*",
    "@refarm.dev/health": "*",
    "@refarm.dev/registry": "*",
    "@refarm.dev/silo": "*",
    "@refarm.dev/sower": "*",
    "@refarm.dev/thresher": "*",
    "@refarm.dev/windmill": "*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.4.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9"
  },
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "access": "public"
  }
}
