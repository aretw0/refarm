{
	"extends": ["../../tsconfig.json", "@refarm.dev/tsconfig/buildable.json"],
	"compilerOptions": {
		"outDir": "dist",
		"baseUrl": "../..",
		"paths": {
			"@refarm.dev/config": ["packages/config/index.d.ts"],
			"@refarm.dev/silo": ["packages/silo/dist/index.d.ts"],
			"@refarm.dev/windmill": ["packages/windmill/dist/index.d.ts"],
			"@refarm.dev/fence": ["packages/fence/dist/index.d.ts"],
			"@refarm.dev/thresher": ["packages/thresher/dist/index.d.ts"],
			"@refarm.dev/health": ["packages/health/dist/index.d.ts"],
			"@refarm.dev/sower": ["packages/sower/dist/index.d.ts"],
			"@refarm.dev/tractor": ["packages/tractor/dist/index.d.ts"],
			"@refarm.dev/homestead/sdk/host-renderer": [
				"packages/homestead/dist/sdk/host-renderer.d.ts"
			],
			"@refarm.dev/trust": ["packages/trust/dist/index.d.ts"],
			"@refarm.dev/runtime": ["packages/runtime/dist/index.d.ts"]
		},
		"maxNodeModuleJsDepth": 2
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
