{
	"extends": [
		"./tsconfig.json",
		"@refarm.dev/tsconfig/build.json"
	],
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"composite": true,
		"paths": {
			"@refarm.dev/locales/*": [
				"locales/*"
			],
			"@refarm.dev/tractor": [
				"packages/tractor/dist/index.d.ts"
			],
			"@refarm.dev/plugin-manifest": [
				"packages/plugin-manifest/src/index.d.ts"
			]
		}
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"src/**/*.astro",
		"src/ui/index.ts"
	]
}
