{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@refarm.dev/locales/*": ["locales/*"],
      "@refarm.dev/tractor": ["packages/tractor/dist/index.d.ts"],
      "@refarm.dev/plugin-manifest": ["packages/plugin-manifest/dist/index.d.ts"]
    },
    "noEmit": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/**/*.astro",
    "src/ui/index.ts"
  ]
}
