{
  "name": "@refarm.dev/homestead",
  "version": "0.1.0",
  "description": "Refarm Homestead — Shared Shell SDK and UI Primitives",
  "type": "module",
  "exports": {
    "./sdk": {
      "types": "./dist/sdk/index.js",
      "import": "./dist/sdk/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.js",
      "import": "./dist/ui/index.js"
    },
    "./styles/*": "./dist/styles/*"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "type-check:dist": "tsc --project tsconfig.build.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@refarm.dev/tractor": "*",
    "astro": "^5.3.0"
  },
  "devDependencies": {
    "@refarm.dev/config": "*",
    "@refarm.dev/tsconfig": "*",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
