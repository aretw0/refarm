{
	"name": "@refarm.dev/node-contract-v1",
	"scaffold": {
		"type": "exempt",
		"reason": "structural types only (GraphNode base interface) — extended by domain contracts; no runtime adapter surface to validate"
	},
	"version": "0.1.0",
	"private": true,
	"description": "Base GraphNode interface — shared fields for all typed nodes in the Refarm sovereign data graph",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --project tsconfig.build.json --watch",
		"type-check": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"clean": "rm -rf dist",
		"lint": "eslint src"
	},
	"devDependencies": {
		"@refarm.dev/tsconfig": "workspace:*",
		"typescript": "^6.0.3",
		"@refarm.dev/vtconfig": "workspace:*",
		"@refarm.dev/eslint-config": "workspace:*"
	}
}
