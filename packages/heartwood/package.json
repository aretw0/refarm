{
  "name": "@refarm.dev/heartwood",
  "version": "0.1.0",
  "description": "Heartwood: Sovereign Cryptographic Core (WASM)",
  "type": "module",
  "files": [
    "pkg"
  ],
  "main": "./pkg/heartwood.js",
  "module": "./pkg/heartwood.js",
  "types": "./pkg/heartwood.d.ts",
  "scripts": {
    "build:wasm": "RUSTUP_TOOLCHAIN=stable cargo build --target wasm32-wasip1 --release",
    "build:transpile": "npx jco transpile target/wasm32-wasip1/release/refarm_heartwood.wasm -o pkg --name heartwood",
    "build": "npm run build:wasm && npm run build:transpile",
    "test": "cargo test"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.4.2"
  }
}
