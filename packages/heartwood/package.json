{
	"name": "@refarm.dev/heartwood",
	"version": "0.1.0",
	"description": "Heartwood: Sovereign Cryptographic Core (WASM)",
	"type": "module",
	"files": [
		"pkg",
		"README.md"
	],
	"main": "./pkg/heartwood.js",
	"module": "./pkg/heartwood.js",
	"types": "./pkg/heartwood.js",
	"scripts": {
		"build:wasm": "node ../../scripts/ci/cargo-run.mjs --copy wasm32-wasip1/release/refarm_heartwood.wasm dist/refarm_heartwood.wasm component build --target wasm32-wasip1 --release",
		"build:transpile": "jco transpile dist/refarm_heartwood.wasm -o pkg --name heartwood",
		"build": "node ../../scripts/ci/cargo-run.mjs --copy wasm32-wasip1/release/refarm_heartwood.wasm dist/refarm_heartwood.wasm component build --target wasm32-wasip1 --release && jco transpile dist/refarm_heartwood.wasm -o pkg --name heartwood",
		"test": "node ../../scripts/ci/cargo-run.mjs test -- --test-threads=1",
		"test:unit": "node ../../scripts/ci/cargo-run.mjs test -- --test-threads=1",
		"test:integration": "echo 'No integration tests for this crate'"
	},
	"devDependencies": {
		"@bytecodealliance/jco": "catalog:",
		"@refarm.dev/deps": "workspace:*"
	}
}
