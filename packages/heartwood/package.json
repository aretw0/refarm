{
  "name": "@refarm.dev/heartwood",
  "version": "0.1.0",
  "description": "Heartwood: Sovereign Cryptographic Core (WASM)",
  "type": "module",
  "files": [
    "pkg",
    "README.md"
  ],
  "main": "./pkg/heartwood.js",
  "module": "./pkg/heartwood.js",
  "types": "./pkg/heartwood.js",
  "scripts": {
    "build:wasm": "RUSTUP_TOOLCHAIN=stable cargo component build --target wasm32-wasip1 --release",
    "build:transpile": "jco transpile target/wasm32-wasip1/release/refarm_heartwood.wasm -o pkg --name heartwood",
    "build": "npm run build:wasm && npm run build:transpile",
    "test": "RUSTUP_TOOLCHAIN=stable cargo test -- --test-threads=1",
    "test:unit": "npm run test",
    "test:integration": "echo 'No integration tests for this crate'"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.4.2"
  }
}
