{
  "name": "@refarm.dev/plugin-manifest",
  "version": "0.1.0",
  "description": "Plugin manifest schema and validation helpers for Refarm micro-kernel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "plugin",
    "manifest",
    "capability",
    "validation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refarm-dev/refarm.git",
    "directory": "packages/plugin-manifest"
  },
  "homepage": "https://github.com/refarm-dev/refarm/tree/main/packages/plugin-manifest#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
