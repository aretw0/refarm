---
import { Layout } from "@refarm.dev/homestead/ui";
---

<Layout title="{{REFARM_NAME}} — Workspace">
  <div id="loading-overlay" class="loading-state">
    <div class="spinner"></div>
    <p>Opening your personal vault...</p>
  </div>

  <style>
    .loading-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 40vh;
      color: var(--refarm-text-secondary);
      font-family: var(--refarm-font-mono);
    }
    .spinner {
      width: 40px; height: 40px;
      border: 3px solid var(--refarm-bg-elevated);
      border-top: 3px solid var(--refarm-accent-primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-bottom: 1rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</Layout>

<script>
  import { bootStudioRuntime, StudioShell, FireflyPlugin, HeraldPlugin } from "@refarm.dev/homestead/sdk";

  async function boot() {
    try {
      const runtime = await bootStudioRuntime({
        databaseName: "{{REFARM_SLUG}}-main",
        namespace: "workspace",
        identityId: "workspace",
        identityPublicKey: "me",
        envMetadata: { version: "0.1.0", commit: "{{REFARM_SLUG}}" }
      });
      const { tractor } = runtime;

      new HeraldPlugin(tractor).announce();
      new FireflyPlugin(tractor);

      const shell = new StudioShell(tractor);
      await shell.setup();

      document.getElementById("loading-overlay")?.remove();

    } catch (err) {
      console.error("[{{REFARM_SLUG}}] Boot failed", err);
    }
  }

  boot();
</script>
