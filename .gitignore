# =============================================================================
# Refarm Monorepo — .gitignore
# Covers: Node.js, Turborepo, Astro, Rust/WASM, SQLite, OS artifacts
# =============================================================================

# ─── Turborepo ───────────────────────────────────────────────────────────────
.turbo/

# ─── Node / Package Managers ─────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Build Outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.output/

# Astro
.astro/

# ─── Rust / WebAssembly ───────────────────────────────────────────────────────
target/
pkg/
wasm-pack.log
Cargo.lock          # Only for libraries (apps should keep their own)

# Compiled WASM outputs (keep .wat source, ignore compiled binary)
*.wasm
# Exception: checked-in WASM fixtures used in tests
!**/fixtures/**/*.wasm
!**/__fixtures__/**/*.wasm

# ─── WIT / Component Model ───────────────────────────────────────────────────
# Compiled component binaries (re-generated from .wit sources)
*.wasm.component
.jco-cache/
.jco-dist/
**/.jco-cache/
**/.jco-dist/

# ─── SQLite / OPFS ───────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
*.db
*.db-shm
*.db-wal

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
.refarm/*.key

# ─── Git Worktrees ───────────────────────────────────────────────────────────
.worktrees/

# ─── Test Coverage & Reports ─────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
*.js.map
*.d.ts.map
*.d.mts.map
*.d.cts.map

# Ignore in-place JS/DTS emissions (source is always .ts)
# Test byproducts and Local Identity
.refarm/

# Standard: All compiled outputs go to dist/
# Use a more targeted approach for packages
packages/**/dist/
packages/**/build/
packages/**/.turbo/

# ─── Editor & IDE ─────────────────────────────────────────────────────────────
.claude/agents/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Miscellaneous ────────────────────────────────────────────────────────────
.cache/
tmp/
temp/
deps-report.md

# ─── Benchmarks ───────────────────────────────────────────────────────────────
# Keep baseline.json versioned, ignore temporary outputs
**/benchmarks/current.json
**/benchmarks/report.md

# ─── Generated Github Tag Artifacts ───────────────────────────────────────────────
# Ignore generated test output files
**/*_tags.txt

# Ignore export plans
*_plan*.md
*prompt*.md

# Python bytecode
__pycache__/
*.pyc
*.pyo
