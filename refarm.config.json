    "phases": [
      {
        "id": "preflight",
        "name": "Preflight",
        "commands": [
          "git status --porcelain"
        ],
        "required": true,
        "riskWeight": 1
      },
      {
        "id": "quality",
        "name": "Quality Gates",
        "commands": [
          "pnpm run lint",
          "pnpm run type-check"
        ],
        "required": true,
        "riskWeight": 5
      },
      {
        "id": "contracts",
        "name": "Contract Smoke",
        "commands": [
          "pnpm run gate:smoke:contracts"
        ],
        "required": true,
        "riskWeight": 6
      },
      {
        "id": "runtime-descriptor",
        "name": "Runtime Descriptor Release Smoke",
        "commands": [
          "pnpm run runtime-descriptor:release-smoke -- --sha local"
        ],
        "required": true,
        "riskWeight": 4
      },
      {
        "id": "telemetry",
        "name": "Telemetry gate",
        "commands": [
          "pnpm run refarm:telemetry:gate:ci -- --out .artifacts/release-engine/telemetry-gate.json --timeout-ms 20000"
        ],
        "required": false,
        "riskWeight": 2
      }
    ]
  }
