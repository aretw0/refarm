{
  "name": "sqlite-benchmark-browser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "setup:wasm": "cp $(node -p \"path.dirname(require.resolve('@sqlite.org/sqlite-wasm/package.json'))\")/dist/sqlite3* public/ && cp $(node -p \"require.resolve('sql.js/dist/sql-wasm.wasm')\") public/",
    "build": "npm run setup:wasm && tsc && vite build",
    "preview": "vite preview",
    "preview:test": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/sql.js": "^1.4.9",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build7",
    "sql.js": "^1.14.1"
  }
}
