{
  "name": "sqlite-benchmark-browser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "setup:wasm": "cp $(node -p \"path.dirname(require.resolve('@sqlite.org/sqlite-wasm/package.json'))\")/dist/sqlite3* public/ && cp $(node -p \"path.dirname(require.resolve('sql.js/dist/sql-wasm.wasm'))\")/sql-wasm*.wasm public/",
    "build": "npm run setup:wasm && tsc && vite build",
    "preview": "vite preview",
    "preview:test": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "preview:test:ci": "node -e \"process.exit(require('fs').existsSync('dist') ? 0 : 1)\" && npm run preview:test || (echo 'dist missing; building before preview...' && npm run build && npm run preview:test)",
    "preview:static": "npm run build && serve dist -l 4174",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit"
  },
  "devDependencies": {
    "@refarm.dev/vtconfig": "*",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/sql.js": "^1.4.11",
    "typescript": "~6.0.3",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build9",
    "sql.js": "^1.14.1"
  }
}
