{
  "name": "sqlite-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:wa-sqlite": "npm run build && node dist/wa-sqlite.bench.js",
    "bench:sql-js": "npm run build && node dist/sql-js.bench.js",
    "bench:all": "npm run bench:wa-sqlite && npm run bench:sql-js",
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/sql.js": "^1.4.11",
    "typescript": "^6.0.3"
  }
}
