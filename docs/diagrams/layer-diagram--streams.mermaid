graph TD
    Farmhand["Farmhand\n(apps/farmhand · Node.js daemon)"]

    subgraph Contracts ["Dispatch Contracts  (packages/)"]
        direction LR
        EffortV1["effort-contract-v1\nEffort · Task · TaskResult"]
        StreamV1["stream-contract-v1\nStreamChunk · StreamTransportAdapter"]
    end

    subgraph EffortAdapters ["Effort Transports"]
        direction LR
        FileAdapt["FileTransportAdapter\n~/.refarm/tasks/ NDJSON"]
        HttpAdapt["HttpTransportAdapter\nport 42001"]
    end

    subgraph StreamAdapters ["Stream Transports"]
        direction LR
        FileStream["FileStreamTransport\n~/.refarm/streams/ NDJSON"]
        SSEStream["SseStreamTransport\nGET /stream/:ref"]
        WSStream["WsStreamTransport\nWS /ws/stream"]
    end

    Farmhand -->|"dispatches via"| EffortV1
    Farmhand -->|"bridges CRDT to"| StreamV1

    EffortV1 -->|"bundled adapter"| FileAdapt
    EffortV1 -->|"bundled adapter"| HttpAdapt

    StreamV1 -->|"bundled adapter"| FileStream
    StreamV1 -->|"bundled adapter"| SSEStream
    StreamV1 -->|"bundled adapter"| WSStream

    classDef app      fill:#dbeafe,stroke:#1d4ed8,stroke-width:1px;
    classDef contract fill:#ede9fe,stroke:#5b21b6,stroke-width:1px;
    classDef transport fill:#e0f2fe,stroke:#075985,stroke-width:1px;

    class Farmhand app;
    class EffortV1,StreamV1 contract;
    class FileAdapt,HttpAdapt,FileStream,SSEStream,WSStream transport;
