graph TD
    %% ── Distros (apps/) ──────────────────────────────────────────────────
    subgraph Distros ["Distros  (apps/)  — opinionated assemblies"]
        direction LR
        Homestead["Homestead\n(Astro / Browser)"]
        RefarmCLI["refarm CLI\n(apps/refarm)"]
    end

    %% ── Runtime Core ─────────────────────────────────────────────────────
    subgraph Core ["Runtime Core  — identical WIT contracts"]
        direction LR
        subgraph TractorTS ["tractor-ts  (TypeScript / browser)"]
            TS_PluginHost["PluginHost\n(JCO transpile)"]
            TS_CRDT["CRDT Store\n(Loro)"]
            TS_Sync["SyncEngine"]
        end
        subgraph TractorRS ["tractor  (Rust / server · edge · Pi)"]
            RS_PluginHost["PluginHost\n(wasmtime + WASI probe)"]
            RS_CRDT["CRDT Store\n(Loro)"]
            RS_Sync["SyncEngine"]
            RS_Sidecar["HTTP Sidecar\n(:42001  ADR-060)"]
        end
    end

    %% ── WIT Contract Layer ───────────────────────────────────────────────
    subgraph WIT ["WIT Contract  (refarm:plugin@0.1.0)"]
        direction LR
        WIT_Pkg["refarm-plugin-wit\n(canonical source)"]
        WIT_Int["integration interface\n(setup · ingest · push · respond · on_event)"]
        WIT_LLM["llm-bridge"]
        WIT_FS["agent-fs / agent-shell"]
        WIT_IO["structured-io / code-ops"]
        WIT_Pkg --> WIT_Int
    end

    %% ── Plugin Sandbox ───────────────────────────────────────────────────
    subgraph Plugins ["Plugin Sandbox  (.wasm — P1 module or P2+ component)"]
        direction LR
        PiAgent["pi-agent\n(sovereign AI)"]
        ThirdParty["third-party plugins"]
    end

    %% ── Capability Contracts (packages/) ─────────────────────────────────
    subgraph Contracts ["Capability Contracts  (packages/)"]
        direction LR
        EffortV1["effort-contract-v1\n(Effort · Task · TaskResult)"]
        StreamV1["stream-contract-v1\n(StreamChunk · StreamTransportAdapter)"]
        StorageV1["storage-contract-v1"]
        SyncV1["sync-contract-v1"]
        IdentityV1["identity-contract-v1"]
    end

    %% ── Transport Adapters ───────────────────────────────────────────────
    subgraph Transports ["Transport Adapters"]
        direction LR
        HttpAdapt["HttpTransportAdapter\n(:42001)"]
        FileStream["FileStreamTransport\n(~/.refarm/streams/ NDJSON)"]
        SSEStream["SseStreamTransport\n(GET /stream/:ref)"]
        WSStream["WsStreamTransport\n(WS /ws/stream)"]
    end

    %% ── Storage & Identity ───────────────────────────────────────────────
    subgraph Storage ["Storage & Identity"]
        direction LR
        SQLite["storage-sqlite\n(OPFS / SQLite)"]
        StoreMem["storage-memory\n(tests)"]
        NostrId["identity-nostr"]
    end

    %% ── Connections ──────────────────────────────────────────────────────
    Homestead -->|"uses tractor-ts"| TractorTS
    RefarmCLI -->|"HTTP :42001"| RS_Sidecar

    TractorTS ---|"same WIT"| WIT_Pkg
    TractorRS ---|"same WIT"| WIT_Pkg

    WIT_Int -->|"implemented by"| PiAgent
    WIT_Int -->|"implemented by"| ThirdParty
    WIT_LLM -.->|"imported by"| PiAgent
    WIT_FS  -.->|"imported by"| PiAgent

    RS_Sidecar -->|"dispatches via"| EffortV1
    RS_Sidecar -->|"writes stream"| FileStream
    EffortV1 -->|"bundled adapters"| HttpAdapt
    StreamV1 -->|"bundled adapters"| SSEStream
    StreamV1 -->|"bundled adapters"| WSStream

    TractorTS -->|"persists via"| StorageV1
    TractorRS -->|"persists via"| StorageV1
    StorageV1 -->|"adapters"| SQLite
    StorageV1 -->|"adapters"| StoreMem
    TractorTS -->|"syncs via"| SyncV1
    TractorRS -->|"syncs via"| SyncV1
    TractorTS -->|"identity via"| IdentityV1
    IdentityV1 -->|"adapter"| NostrId
