graph TD
    subgraph Homestead ["Refarm Homestead (Astro SSG)"]
        HS_SQLite["storage-sqlite"]
        HS_Nostr["identity-nostr"]
    end

    subgraph Tractor ["Refarm Tractor (The Microkernel)"]
        PluginHost["PluginHost (WASI Runtime)"]
        PluginRunner["PluginRunner\n(WorkerRunner / MainThreadRunner)"]
        TelemetryBus["EventEmitter\n(telemetry pub/sub)"]
        Normaliser["Normaliser (→ JSON-LD)"]
        SyncEngine["SyncEngine (CRDT)"]
        Heartwood["Heartwood (WASM Security)"]
        PluginHost -->|"resolves"| PluginRunner
    end

    subgraph Interfaces ["Interfaces & Ports"]
        StoragePort["Storage Port"]
        SyncPort["Sync Port"]
        IdentityPort["Identity Port"]
    end

    subgraph WASM ["Plugin Sandbox"]
        Plugin["Plugin (WASM)"]
    end

    subgraph TEMWorker ["TEM Plugin (WebWorker)"]
        ActionEnc["ActionEncoder\n1-hot vocab"]
        ObsEnc["StructAwareEncoder\n64-dim slots"]
        TEMCore["TEMInference\nHebbian + Attractor"]
    end

    Homestead -->|"Instantiates Adapters"| HS_SQLite
    Homestead -->|"Instantiates Adapters"| HS_Nostr

    HS_SQLite -.->|"Inject"| StoragePort
    HS_Nostr -.->|"Inject"| IdentityPort

    Tractor -->|"Uses"| StoragePort
    Tractor -->|"Uses"| SyncPort
    Tractor -->|"Uses"| Heartwood
    Heartwood -->|"Protects"| IdentityPort

    PluginRunner -->|"WorkerRunner"| TEMWorker
    PluginRunner ---|"WASI Boundary"| Plugin
    Plugin -->|"storeNode"| StoragePort
    Plugin -->|"emit event"| TelemetryBus
    TelemetryBus -->|"observe"| TEMCore
    TEMCore -->|"storeNode\nTemMemory · NoveltyScore"| StoragePort

    Normaliser -->|"Normalise"| StoragePort
    SyncEngine -->|"Sync"| SyncPort
