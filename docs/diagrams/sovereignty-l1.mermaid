graph TD
    subgraph Read ["On every read"]
        R1["Fetch from SQLite / OPFS"] --> R2["Verify row checksum"]
        R2 -->|Mismatch| R3["Attempt recovery"]
        R3 --> R3a["Rollback to last valid\nLoro snapshot"]
        R3 --> R3b["Replay Loro deltas\nfrom snapshot forward"]
        R3 --> R3c["Salvage readable rows\n(partial graph)"]
    end

    subgraph Write ["On every write"]
        W1["Compute + store checksum"] --> W2["Apply Loro delta\n(CQRS projection)"]
        W2 --> W3["Atomic SQLite commit\n(data + CRDT state together)"]
        W3 --> W4["Verify write succeeded\n(row count + checksum)"]
    end
