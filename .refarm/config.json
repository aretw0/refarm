    ],
    "phases": [
      {
        "id": "preflight",
        "name": "Preflight",
        "commands": [
          "git status --porcelain"
        ],
        "required": true,
        "riskWeight": 1
      },
      {
        "id": "quality",
        "name": "Quality Gates",
        "commands": [
          "pnpm run lint",
          "pnpm run type-check"
        ],
        "required": true,
        "riskWeight": 5
      },
      {
        "id": "contracts",
        "name": "Contract Smoke",
        "commands": [
          "pnpm run gate:smoke:contracts"
        ],
        "required": true,
        "riskWeight": 6
      },
      {
        "id": "runtime-descriptor",
        "name": "Runtime Descriptor Release Smoke",
        "commands": [
          "pnpm run runtime-descriptor:release-smoke -- --sha local"
        ],
        "required": true,
        "riskWeight": 4
      },
      {
        "id": "telemetry",
        "name": "Telemetry gate",
        "commands": [
          "pnpm run refarm:telemetry:gate:ci -- --out .artifacts/release-engine/telemetry-gate.json --timeout-ms 20000"
        ],
        "required": false,
        "riskWeight": 2
      }
    ]
  },
  "health": {
    "preset": "refarm",
    "ignoredGitVisibilityPatterns": [
      "**/*.d.ts",
      "packages/pi-agent/src/bindings.rs",
      "validations/sqlite-benchmark/browser/public/sqlite3-opfs-async-proxy.js",
      "validations/sqlite-benchmark/browser/public/sqlite3-worker1.mjs"
    ]
  },
  "automation": {
    "safety": {
      "defaultProfile": "micro-safe",
      "maxDurationMs": 65000,
      "maxDurationMsByProfile": {
        "micro-safe": 65000,
        "micro": 90000,
        "normal": 240000,
        "full": 420000
      },
      "profiles": {
        "micro-safe": [
          {
            "id": "env-safety",
            "command": ["bash", "scripts/env-safety-check.sh", "--warn"],
            "timeoutMs": 30000
          },
          {
            "id": "workspace-resolution",
            "command": ["node", "packages/toolbox/src/cli.mjs", "reso", "status"],
            "timeoutMs": 15000
          },
          {
            "id": "ci-loop-signal",
            "command": [
              "node",
              "scripts/pi-session-heavy.mjs",
              "--recent",
              "1",
              "--count",
              "20",
              "--filter",
              "gh ",
              "--ci-loop-signal",
              "--ci-loop-max-count",
              "6",
              "--ci-loop-max-ms",
              "360000"
            ],
            "timeoutMs": 120000,
            "required": false
          }
        ],
        "micro-safe-baseline": [
          {
            "id": "env-safety",
            "command": ["bash", "scripts/env-safety-check.sh", "--warn"],
            "timeoutMs": 60000,
            "required": false
          },
          {
            "id": "workspace-resolution",
            "command": ["node", "packages/toolbox/src/cli.mjs", "reso", "status"],
            "timeoutMs": 15000,
            "required": false
          },
          {
            "id": "ci-loop-baseline",
            "command": [
              "node",
              "scripts/pi-session-heavy.mjs",
              "--recent",
              "5",
              "--count",
              "30",
              "--filter",
              "gh ",
              "--ci-loop-max-count",
              "12",
              "--ci-loop-max-ms",
              "900000"
            ],
            "timeoutMs": 120000,
            "required": false
          }
        ],
        "micro": [
          {
            "id": "env-safety",
            "command": ["bash", "scripts/env-safety-check.sh", "--warn"],
            "timeoutMs": 30000
          },
          {
            "id": "workspace-resolution",
            "command": ["node", "packages/toolbox/src/cli.mjs", "reso", "status"],
            "timeoutMs": 15000
          },
          {
            "id": "operator-resume",
            "command": ["refarm", "resume", "--json"],
            "timeoutMs": 60000,
            "required": false
          },
          {
            "id": "operator-next-action",
            "command": ["refarm", "check", "--next-action", "--json"],
            "timeoutMs": 60000,
            "required": false
          }
        ],
        "normal": [
          {
            "id": "workspace-resolution",
            "command": ["node", "packages/toolbox/src/cli.mjs", "reso", "status"],
            "timeoutMs": 15000
          },
          {
            "id": "env-safety-strict",
            "command": ["bash", "scripts/env-safety-check.sh", "--strict"],
            "timeoutMs": 30000
          },
          {
            "id": "refarm-target-type-check",
            "command": [
              "node",
              "scripts/ci/run-package-binary.mjs",
              "pnpm",
              "exec",
              "turbo",
              "run",
              "type-check",
              "--filter=./apps/refarm",
              "--cache-dir=.turbo"
            ],
            "timeoutMs": 180000
          },
          {
            "id": "refarm-target-unit-tests",
            "command": [
              "node",
              "scripts/ci/run-package-binary.mjs",
              "pnpm",
              "exec",
              "turbo",
              "run",
              "test:unit",
              "--filter=./apps/refarm",
              "--cache-dir=.turbo"
            ],
            "timeoutMs": 240000
          }
        ],
        "full": [
          {
            "id": "workspace-resolution",
            "command": ["node", "packages/toolbox/src/cli.mjs", "reso", "status"],
            "timeoutMs": 15000
          },
          {
            "id": "env-safety-strict",
            "command": ["bash", "scripts/env-safety-check.sh", "--strict"],
            "timeoutMs": 30000
          },
          {
            "id": "operator-check-gate",
            "command": ["node", "scripts/ci/refarm-check-gate.mjs", "check"],
            "timeoutMs": 480000
          },
          {
            "id": "refarm-target-lint",
            "command": [
              "node",
              "scripts/ci/run-package-binary.mjs",
              "pnpm",
              "exec",
              "turbo",
              "run",
              "lint",
              "--filter=./apps/refarm",
              "--cache-dir=.turbo"
            ],
            "timeoutMs": 240000
          },
          {
            "id": "refarm-target-type-check",
            "command": [
              "node",
              "scripts/ci/run-package-binary.mjs",
              "pnpm",
              "exec",
              "turbo",
              "run",
              "type-check",
              "--filter=./apps/refarm",
              "--cache-dir=.turbo"
            ],
            "timeoutMs": 240000
          },
          {
            "id": "refarm-target-integration-tests",
            "command": [
              "node",
              "scripts/ci/run-package-binary.mjs",
              "pnpm",
              "exec",
              "turbo",
              "run",
              "test:integration",
              "--filter=./apps/refarm",
              "--cache-dir=.turbo"
            ],
            "timeoutMs": 360000
          }
        ]
      }
    }
  }
}
